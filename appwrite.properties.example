# =============================================================================
# Optional: template if you fork this repo and use your own Appwrite project
# =============================================================================
#
# This repository includes a committed `appwrite.properties` so teammates can
# build without a separate handoff. For a private fork, replace values below
# (Console → Settings / Databases / Storage) and keep Android platform:
#   com.wpi.backtoowner
#
# Endpoint must match your project's region (e.g. fra.cloud.appwrite.io).

appwrite.endpoint=https://fra.cloud.appwrite.io/v1
appwrite.projectId=
appwrite.databaseId=
appwrite.storageBucketId=
